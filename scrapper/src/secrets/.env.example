host=your_host # 0.0.0.0
port=your_port # 8001
access_type=your_access_type # orm, raw
GITHUB_TOKEN=your_token
BOT_URL=your_bot_url # http://localhost:8000

POSTGRES_DB=your_db # postgres
POSTGRES_HOST=your_host # localhosts
POSTGRES_PORT=your_port # 5432
POSTGRES_PASSWORD=your_postgres_password # admin
POSTGRES_USER=your_user # postgres

KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_TOPIC=link-updates
NOTIFICATION_TYPE=http # http, kafka

LOGGER_LEVEL=INFO
LOGGER_OUTPUT=stdout # stdout=console or filename

BATCH_SIZE=100 # links will be checked in one scheduler tick
UPDATE_TIME=100 # scheduler tick freeze in second
CONCURRENCY_LINKS=10 # count of links checked concurrency

SCHEMA_REGISTRY_URL: str = "http://localhost:8081"

VALKEY_HOST: str = "localhost"
VALKEY_PORT: int = 6379
VALKEY_TTL: int = 300
